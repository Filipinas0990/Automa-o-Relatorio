# ─────────────────────────────────────────────────────────────────────────────
# PharmaFlow — variáveis de ambiente
# Copie para .env e preencha os valores reais
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados
DATABASE_URL=postgresql://farmacia:farmacia123@localhost:5432/farmacia_monitor

# JWT
JWT_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
ADMIN_SECRET=segredo-para-criar-o-super-admin

# Servidor
PORT=8000
LOG_LEVEL=info

# Frontend (usado no redirect após OAuth do Google)
FRONTEND_URL=https://pharmarelatorios.online

# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar — Integração OAuth2
# Como configurar:
#   1. Acesse https://console.cloud.google.com/
#   2. Crie um projeto (ou use um existente)
#   3. Ative a "Google Calendar API" em "APIs e Serviços"
#   4. Em "Credenciais" → "Criar credenciais" → "ID do cliente OAuth 2.0"
#   5. Tipo: "Aplicativo da Web"
#   6. URI de redirecionamento autorizado: ${GOOGLE_REDIRECT_URI} abaixo
#   7. Copie Client ID e Client Secret aqui
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-SEU_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://api.pharmarelatorios.online/api/auth/google/callback
